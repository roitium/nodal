DATABASE_URL=postgresql://user:password@host:6543/database
JWT_SECRET=replace-with-a-long-random-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
STORAGE_BUCKET=nodal-resources
STORAGE_PROVIDER=supabase
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# ^ IMPORTANT: Pure endpoint WITHOUT bucket name in path. DO NOT use:
#   https://<account_id>.r2.cloudflarestorage.com/bucket-name  ❌
# Use only:
#   https://<account_id>.r2.cloudflarestorage.com  ✅
S3_ACCESS_KEY_ID=<access_key_id>
S3_SECRET_ACCESS_KEY=<secret_access_key>
S3_REGION=auto
